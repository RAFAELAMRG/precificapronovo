// Prisma Schema for PrecificaPro (Marketplace Pricing SaaS)
// Configured to run on PostgreSQL for production SaaS.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Companies Table
model Company {
  id         String   @id @default(uuid())
  nome       String
  email      String
  telefone   String
  plano      String   @default("pro") // "pro", "master"
  status     String   @default("ativo") // "ativo", "bloqueado"
  created_at DateTime @default(now())

  users            User[]
  subscription     Subscription? // 1-to-1 SaaS Subscription relation
  products         Product[]
  alerts           Alert[]
  pricing_history  PricingHistory[]
  production_costs ProductionCost[]

  @@map("companies")
}

// 2. Users Table
model User {
  id         String   @id @default(uuid())
  company_id String
  nome       String
  email      String   @unique
  senha      String // bcrypt hashed password
  role       String   @default("cliente") // "admin" (Admin Master), "cliente" (Client)
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("users")
}

// 3. Subscriptions Table (Asaas Billing & Gating)
model Subscription {
  id                    String    @id @default(uuid())
  company_id            String    @unique // Unique for 1-to-1 mapping
  plan                  String    @default("pro") // "pro", "free"
  status                String    @default("trial") // "trial", "active", "pending", "expired", "blocked", "cancelled"
  asaas_customer_id     String? // Asaas Customer ID (cus_...)
  asaas_subscription_id String? // Asaas Subscription ID (sub_...)
  trial_ends_at         DateTime // Grace period threshold
  expires_at            DateTime? // Next payment due expiration date
  manual_release        Boolean   @default(false) // Admin override bypass
  created_at            DateTime  @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// 4. Products Table
model Product {
  id             String   @id @default(uuid())
  company_id     String
  nome           String
  sku            String
  marketplace    String // "mercado_livre", "shopee", "amazon", "magalu", "shein", "tiktok_shop", "olist", "webcontinental"
  custo_tipo     String   @default("revenda") // "revenda", "fabricacao", "confeccao"
  detalhes_custo String? // JSON string holding details of materials, yields, outsourced costs
  custo          Float // Custo do produto calculado
  frete          Float // Frete de envio
  embalagem      Float    @default(0.0)
  imposto        Float    @default(0.0) // Imposto em %
  comissao       Float    @default(0.0) // Comissão em %
  margem         Float    @default(0.0) // Margem desejada em %
  preco_atual    Float // Preço praticado
  preco_ideal    Float    @default(0.0)
  lucro          Float    @default(0.0)
  status         String   @default("ativo")
  created_at     DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  production_cost_id String?
  production_cost    ProductionCost? @relation(fields: [production_cost_id], references: [id], onDelete: SetNull)

  @@map("products")
}

// 5. Pricing History Audit Table
model PricingHistory {
  id             String   @id @default(uuid())
  company_id     String
  product_id     String
  preco_anterior Float
  preco_novo     Float
  lucro_anterior Float
  lucro_novo     Float
  created_at     DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("pricing_history")
}

// 6. Alerts Table
model Alert {
  id         String   @id @default(uuid())
  company_id String
  tipo       String // "prejuizo", "margem_baixa", "desatualizado", "taxa_alta"
  mensagem   String
  status     String   @default("nao_lido") // "lido", "nao_lido"
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("alerts")
}

// 7. Production Costs (Fichas de Custo)
model ProductionCost {
  id             String   @id @default(uuid())
  company_id     String
  sku            String
  nome           String
  custo_tipo     String // "fabricacao" or "confeccao"
  detalhes_custo String // JSON string for fabrics, raw materials, labor, services
  custo_total    Float
  created_at     DateTime @default(now())

  company  Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  products Product[] // Link to products that consume this cost

  @@unique([company_id, sku])
  @@map("production_costs")
}
